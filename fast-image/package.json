{
  "name": "rename-gui",
  "version": "1.6.0",
  "author": "NhanHo",
  "description": "Premium Fast Image Siêu Cấp VIP PRO",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.nhanho.fastrenamevip",
    "productName": "Fast Image Siêu Cấp VIP PRO",
    "copyright": "Copyright © 2026 NhanHo",
    "electronLanguages": [
      "en-US",
      "vi"
    ],
    "compression": "maximum",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "logo-app-256.png"
    },
    "electronDownload": {
      "isVerifyChecksum": false
    }
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "fs-extra": "^11.3.0",
    "sharp": "^0.34.5",
    "sortablejs": "^1.15.7"
  }
}